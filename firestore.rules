rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı Fonksiyon: Admin kontrolü ───
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'talatozdemir00@gmail.com';
    }

    // ─── Sessions Koleksiyonu ───
    match /Sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // ─── Users Koleksiyonu ───
    match /Users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Sadece Cloud Functions yazabilir
    }

    // ─── Participations Koleksiyonu ───
    match /Participations/{participationId} {
      allow read: if request.auth != null;
      allow write: if false; // Sadece Cloud Functions yazabilir
    }
  }
}